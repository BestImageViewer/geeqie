<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="menu-search">
    <section>
      <item>
        <attribute name="action">win.search-win-play</attribute>
        <attribute name="label" translatable="yes">Play</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="action">win.search-win-view</attribute>
        <attribute name="label" translatable="yes">View</attribute>
      </item>
      <item>
        <attribute name="action">win.search-win-view-in-new-window</attribute>
        <attribute name="label" translatable="yes">View in new window</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="action">win.search-win-select-all</attribute>
        <attribute name="label" translatable="yes">Select all</attribute>
      </item>
      <item>
        <attribute name="action">win.search-win-select-none</attribute>
        <attribute name="label" translatable="yes">Select none</attribute>
      </item>
    </section>
    <section>
      <submenu>
        <section id="plugins-submenu" />
        <attribute name="label">Plugins</attribute>
      </submenu>
    </section>
    <section>
      <submenu>
        <attribute name="label">Add to Collection</attribute>
        <section>
          <item>
            <attribute name="action">win.search-win-collections</attribute>
            <attribute name="label" translatable="yes">New collection</attribute>
            <attribute name="target" type="i">-1</attribute>
          </item>
        </section>
        <section id="collections-submenu" />
      </submenu>
      <item>
        <attribute name="action">win.search-win-print</attribute>
        <attribute name="label" translatable="yes">Print…</attribute>
      </item>
    </section>
    <section>
      <item>
        <attribute name="action">win.search-win-copy</attribute>
        <attribute name="label" translatable="yes">Copy…</attribute>
      </item>
      <item>
        <attribute name="action">win.search-win-move</attribute>
        <attribute name="label" translatable="yes">Move…</attribute>
      </item>
      <item>
        <attribute name="action">win.search-win-rename</attribute>
        <attribute name="label" translatable="yes">Rename…</attribute>
      </item>
      <item>
        <attribute name="action">win.search-win-copy-path</attribute>
        <attribute name="label" translatable="yes">Copy path</attribute>
      </item>
      <item>
        <attribute name="action">win.search-win-copy-path-unquoted</attribute>
        <attribute name="label" translatable="yes">Copy path unquoted</attribute>
      </item>
    </section>
    <section id="delete-section">
      <item>
        <attribute name="action">win.search-win-delete</attribute>
        <attribute name="label" translatable="yes">Move selection to trash</attribute>
      </item>
      <item>
        <attribute name="action">win.search-win-delete-permanent</attribute>
        <attribute name="label" translatable="yes">Delete</attribute>
      </item>
    </section>
  </menu>
</interface>
